      "type": [
        "string",
        "null"
      ]
    },
    "data": {
      "type": "string"
    },
    "txHash": {
      "type": "string"
    },
    "blockNumber": {
      "type": [
        "integer",
        "null"
      ],
      "readOnly": true
    },
    "transfers": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/TransferWithTokenInfoResponse"
      }
    },
    "txType": {
      "type": "string",
      "readOnly": true
    },
    "from": {
      "type": "string"
    }
