      "required": true,
      "description": "",
      "schema": {
        "type": "string"
      }
    }
  ],
  "requestBody": {
    "content": {
      "application/json": {
        "schema": {
          "$ref": "#/components/schemas/SafeMessageSignature"
        }
      }
    },
    "required": true
  },
  "responses": {
    "201": {
      "description": "Created",
      "content": {}
    }
  }
}