        "type": "string"
      }
    }
  ],
  "requestBody": {
    "content": {
      "application/json": {
        "schema": {
          "$ref": "#/components/schemas/SafeMultisigConfirmation"
        }
      }
    },
    "required": true
  },
  "responses": {
    "201": {
      "description": "Created",
      "content": {}
    },
    "400": {
      "description": "Malformed data",
      "content": {}
    },
    "422": {
      "description": "Error processing data",
      "content": {}
    }
  }
}